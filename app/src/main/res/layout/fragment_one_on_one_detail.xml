<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Header: Name + Datum + Save -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="@color/template_oneonone">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_member"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:layout_marginEnd="4dp"
            android:hint="@string/field_name">
            <AutoCompleteTextView
                android:id="@+id/et_member"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPersonName|textCapWords"
                android:completionThreshold="1"
                android:background="#FFFFFF" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_datum"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:hint="@string/field_datum">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_datum"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:focusable="false"
                android:clickable="true"
                android:background="#FFFFFF" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:text="@string/action_save"
            android:textColor="#FFFFFF"
            app:strokeColor="#FFFFFF"
            xmlns:app="http://schemas.android.com/apk/res-auto" />

    </LinearLayout>

    <com.groundwork.programmieramt.pen.PenToolbarView
        android:id="@+id/pen_toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <!-- Full-screen drawing canvas -->
    <com.groundwork.programmieramt.pen.DrawingSurfaceView
        android:id="@+id/drawing_surface"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
